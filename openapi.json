{
  "openapi": "3.1.0",
  "info": {
    "title": "cdd-ctl",
    "description": "",
    "license": {
      "name": ""
    },
    "version": "0.1.0"
  },
  "paths": {
    "/auth/github": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Login with GitHub OAuth",
        "operationId": "login_github",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OAuthPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated via GitHub",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "OAuth failed"
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Login with username/password",
        "operationId": "login_password",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successfully authenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Register a new user",
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successfully registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          }
        }
      }
    },
    "/github/actions/dispatch": {
      "post": {
        "tags": [
          "github"
        ],
        "summary": "Trigger a GitHub Actions Workflow",
        "operationId": "trigger_action",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TriggerWorkflowPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Workflow dispatched"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/github/releases": {
      "post": {
        "tags": [
          "github"
        ],
        "summary": "Create a GitHub Release",
        "operationId": "create_release",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReleasePayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Release created"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/github/secrets": {
      "post": {
        "tags": [
          "github"
        ],
        "summary": "Create a GitHub Secret",
        "operationId": "create_secret",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSecretPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Secret created"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/github/sync": {
      "post": {
        "tags": [
          "github"
        ],
        "summary": "Sync users, organizations, repositories, and releases from GitHub API",
        "operationId": "sync_github_data",
        "responses": {
          "200": {
            "description": "Sync completed successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SyncStatus"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/github/webhook": {
      "post": {
        "tags": [
          "github"
        ],
        "summary": "Receive GitHub Webhooks",
        "operationId": "webhook_receiver",
        "responses": {
          "200": {
            "description": "Webhook processed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WebhookResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid signature"
          }
        }
      }
    },
    "/orgs": {
      "post": {
        "tags": [
          "orgs"
        ],
        "summary": "Create a new organization",
        "operationId": "create_org",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrgPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Organization created successfully"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/repos": {
      "post": {
        "tags": [
          "repos"
        ],
        "summary": "Create a new Repository (SDK project)",
        "operationId": "create_repo",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RepoPayload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Repository created successfully"
          },
          "403": {
            "description": "Forbidden - Not an owner of the organization"
          },
          "500": {
            "description": "Internal Server Error"
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/rpc": {
      "post": {
        "tags": [
          "rpc"
        ],
        "summary": "The core JSON-RPC request handler",
        "operationId": "rpc_handler",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RpcRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "JSON-RPC response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RpcResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer_auth": []
          }
        ]
      }
    },
    "/version": {
      "get": {
        "tags": [],
        "summary": "Get API version",
        "operationId": "version",
        "responses": {
          "200": {
            "description": "Version info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthResponse": {
        "type": "object",
        "description": "Response containing the JWT token",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string",
            "description": "JWT token"
          }
        }
      },
      "CreateSecretPayload": {
        "type": "object",
        "description": "CreateSecretPayload structure",
        "required": [
          "owner",
          "repo",
          "secret_name",
          "secret_value"
        ],
        "properties": {
          "owner": {
            "type": "string",
            "description": "owner field"
          },
          "repo": {
            "type": "string",
            "description": "repo field"
          },
          "secret_name": {
            "type": "string",
            "description": "secret_name field"
          },
          "secret_value": {
            "type": "string",
            "description": "secret_value field"
          }
        }
      },
      "LoginPayload": {
        "type": "object",
        "description": "Payload for logging in with username/password",
        "required": [
          "username"
        ],
        "properties": {
          "password": {
            "type": [
              "string",
              "null"
            ],
            "description": "Password"
          },
          "username": {
            "type": "string",
            "description": "Username"
          }
        }
      },
      "OAuthPayload": {
        "type": "object",
        "description": "Payload for OAuth login",
        "required": [
          "code"
        ],
        "properties": {
          "code": {
            "type": "string",
            "description": "OAuth authorization code"
          }
        }
      },
      "OrgPayload": {
        "type": "object",
        "description": "Payload for creating an organization",
        "required": [
          "login"
        ],
        "properties": {
          "description": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional description"
          },
          "login": {
            "type": "string",
            "description": "Login/name for the organization"
          }
        }
      },
      "Organization": {
        "type": "object",
        "description": "Organization model synced from GitHub or created locally",
        "required": [
          "id",
          "login"
        ],
        "properties": {
          "description": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional description"
          },
          "github_id": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "GitHub ID"
          },
          "id": {
            "type": "integer",
            "format": "int32",
            "description": "Internal DB ID"
          },
          "login": {
            "type": "string",
            "description": "Login or name"
          }
        }
      },
      "RegisterPayload": {
        "type": "object",
        "description": "Payload for registering a new user",
        "required": [
          "username",
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "description": "Email address"
          },
          "password": {
            "type": [
              "string",
              "null"
            ],
            "description": "Password"
          },
          "username": {
            "type": "string",
            "description": "Desired username"
          }
        }
      },
      "ReleasePayload": {
        "type": "object",
        "description": "ReleasePayload structure",
        "required": [
          "owner",
          "repo",
          "tag_name"
        ],
        "properties": {
          "body": {
            "type": [
              "string",
              "null"
            ],
            "description": "body field"
          },
          "name": {
            "type": [
              "string",
              "null"
            ],
            "description": "name field"
          },
          "owner": {
            "type": "string",
            "description": "owner field"
          },
          "repo": {
            "type": "string",
            "description": "repo field"
          },
          "tag_name": {
            "type": "string",
            "description": "tag_name field"
          }
        }
      },
      "RepoPayload": {
        "type": "object",
        "description": "Payload for creating a repository",
        "required": [
          "organization_id",
          "name"
        ],
        "properties": {
          "description": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional description"
          },
          "name": {
            "type": "string",
            "description": "Name of the repository"
          },
          "organization_id": {
            "type": "integer",
            "format": "int32",
            "description": "ID of the organization to own this repository"
          }
        }
      },
      "Repository": {
        "type": "object",
        "description": "Repository model representing SDKs",
        "required": [
          "id",
          "organization_id",
          "name"
        ],
        "properties": {
          "description": {
            "type": [
              "string",
              "null"
            ],
            "description": "Optional description"
          },
          "github_id": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "Optional GitHub ID"
          },
          "id": {
            "type": "integer",
            "format": "int32",
            "description": "Internal DB ID"
          },
          "name": {
            "type": "string",
            "description": "Name"
          },
          "organization_id": {
            "type": "integer",
            "format": "int32",
            "description": "Organization ID"
          }
        }
      },
      "RpcError": {
        "type": "object",
        "description": "A JSON-RPC 2.0 Error object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          }
        }
      },
      "RpcRequest": {
        "type": "object",
        "description": "A JSON-RPC 2.0 Request payload",
        "required": [
          "jsonrpc",
          "method"
        ],
        "properties": {
          "id": {
            "type": [
              "object",
              "null"
            ],
            "description": "Request ID (optional)"
          },
          "jsonrpc": {
            "type": "string",
            "description": "JSON-RPC version (must be \"2.0\")",
            "example": "2.0"
          },
          "method": {
            "type": "string",
            "description": "The method to invoke",
            "example": "version"
          },
          "params": {
            "type": [
              "object",
              "null"
            ],
            "description": "Parameters for the method (optional)"
          }
        }
      },
      "RpcResponse": {
        "type": "object",
        "description": "A JSON-RPC 2.0 Response payload",
        "required": [
          "jsonrpc"
        ],
        "properties": {
          "error": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/RpcError",
                "description": "Error payload"
              }
            ]
          },
          "id": {
            "type": [
              "object",
              "null"
            ],
            "description": "Correlated request ID"
          },
          "jsonrpc": {
            "type": "string",
            "description": "JSON-RPC version (always \"2.0\")",
            "example": "2.0"
          },
          "result": {
            "type": [
              "object",
              "null"
            ],
            "description": "Successful result payload"
          }
        }
      },
      "SyncStatus": {
        "type": "object",
        "description": "Response payload indicating sync status",
        "required": [
          "success",
          "message"
        ],
        "properties": {
          "message": {
            "type": "string",
            "description": "Detailed message about sync status"
          },
          "success": {
            "type": "boolean",
            "description": "True if sync was successful"
          }
        }
      },
      "TriggerWorkflowPayload": {
        "type": "object",
        "description": "TriggerWorkflowPayload structure",
        "required": [
          "owner",
          "repo",
          "workflow_id",
          "ref_branch"
        ],
        "properties": {
          "owner": {
            "type": "string",
            "description": "owner field"
          },
          "ref_branch": {
            "type": "string",
            "description": "ref_branch field"
          },
          "repo": {
            "type": "string",
            "description": "repo field"
          },
          "workflow_id": {
            "type": "string",
            "description": "workflow_id field"
          }
        }
      },
      "VersionResponse": {
        "type": "object",
        "description": "The response payload for the version endpoint.",
        "required": [
          "version"
        ],
        "properties": {
          "version": {
            "type": "string",
            "description": "The current application version"
          }
        }
      },
      "WebhookResponse": {
        "type": "object",
        "description": "WebhookResponse structure",
        "required": [
          "success"
        ],
        "properties": {
          "success": {
            "type": "boolean",
            "description": "success field"
          }
        }
      }
    },
    "securitySchemes": {
      "bearer_auth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "tags": [
    {
      "name": "cdd-ctl",
      "description": "Control daemon for CDD JSON-RPC servers"
    }
  ]
}